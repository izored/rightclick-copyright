# ============================================================
#  izored Copyright Tool — Configuration Template
#  Copy this file to .env ONE FOLDER ABOVE this repo.
#  Example: if repo is at C:\Scripts\copyright\
#           put .env at  C:\Scripts\.env
#  .env is never committed — your data stays local.
# ============================================================

# --- WHO YOU ARE ---

# Short name embedded as the image Artist (EXIF: Artist)
ARTIST_NAME=Your Name

# Full credit line: Studio - website - Legal name (EXIF: Creator)
CREATOR_CREDIT=Your Studio - your.site - Your Legal Name

# The copyright string embedded in every image (EXIF: Copyright, Rights)
COPYRIGHT_TEXT=© 2025 Your Name. All rights reserved.

# Your website, embedded as source URL (EXIF: URL, Source)
WEBSITE=https://your.site

# --- WHAT GETS EMBEDDED IN EVERY IMAGE ---

# Default title tagged on each image (EXIF: Title)
IMAGE_DEFAULT_TITLE=Your Artwork Title

# Default description / caption (EXIF: Description, Caption)
IMAGE_DEFAULT_DESCRIPTION=Artwork created by Your Name.

# Comma-separated keywords (EXIF: Keywords)
IMAGE_DEFAULT_KEYWORDS=art, photography, creative

# --- MONITOR SCRIPT ---

# Folder watched by monitor-copyright.ps1 for new images
WATCH_FOLDER=C:\Path\To\Your\Output\Folder
